modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[[ports]]
localPort = 5098
externalPort = 5173

[[ports]]
localPort = 5099
externalPort = 3003

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 4200

[[ports]]
localPort = 18115
externalPort = 3002

[[ports]]
localPort = 18116
externalPort = 5000

[[ports]]
localPort = 21235
externalPort = 3000

[[ports]]
localPort = 23744
externalPort = 3001

[nix]
channel = "stable-25_05"

[userenv]

