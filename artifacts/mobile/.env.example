# Local development env for the mobile app (Expo).
# Copy this file to `.env` (gitignored) and fill in the values, then run `npx expo start`.
#
# Notes:
# - EXPO_PUBLIC_* vars are inlined into the bundle at build time; after editing
#   `.env`, restart with cache cleared: `npx expo start --clear`.
# - This file is for LOCAL dev only. EAS cloud builds do NOT read it — they use
#   the `env` block of each profile in `eas.json`.

# API host to target (NO https:// prefix — the app prepends https:// itself).
# Use the test backend for development:
EXPO_PUBLIC_DOMAIN=api.test.zbarber.net

# Clerk Frontend-API proxy (production proxy, shared by all builds — Option A).
EXPO_PUBLIC_CLERK_PROXY_URL=https://zbarber.net/api/__clerk

# Clerk PRODUCTION publishable key (public, pk_live_...).
# Get it from the Clerk dashboard (API keys → production instance),
# or from CLERK_PUBLISHABLE_KEY in api-prod.env.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_REPLACE_WITH_REAL_PROD_KEY
