{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_DOMAIN": "api.test.zbarber.net",
        "EXPO_PUBLIC_CLERK_PROXY_URL": "https://api.test.zbarber.net/api/__clerk",
        "EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY": "pk_live_REPLACE_WITH_TEST_KEY"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_DOMAIN": "api.test.zbarber.net",
        "EXPO_PUBLIC_CLERK_PROXY_URL": "https://api.test.zbarber.net/api/__clerk",
        "EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY": "pk_live_REPLACE_WITH_TEST_KEY"
      }
    },
    "test": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_DOMAIN": "api.test.zbarber.net",
        "EXPO_PUBLIC_CLERK_PROXY_URL": "https://api.test.zbarber.net/api/__clerk",
        "EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY": "pk_live_REPLACE_WITH_TEST_KEY"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_DOMAIN": "api.zbarber.net",
        "EXPO_PUBLIC_CLERK_PROXY_URL": "https://api.zbarber.net/api/__clerk",
        "EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY": "pk_live_REPLACE_WITH_PROD_KEY"
      }
    }
  },
  "submit": {
    "test": {},
    "production": {}
  }
}
