# Zbarber API environment file (example).
#
# Copy to the VPS as:
#   /etc/zbarber/api-prod.env   (PORT=5001, prod database)
#   /etc/zbarber/api-test.env   (PORT=5002, test database)
#
# These files are read by the systemd services (EnvironmentFile=...).
# NEVER commit the filled-in versions — only this .example is tracked.

NODE_ENV=production

# Port the API listens on (localhost only; nginx proxies to it).
# prod = 5001, test = 5002
PORT=5001

# Optional log level (default info)
# LOG_LEVEL=info

# --- Database (use a SEPARATE database for prod and test) ---
DATABASE_URL=postgres://user:password@127.0.0.1:5432/zbarber_prod

# --- Session / admin JWT secrets ---
SESSION_SECRET=change-me-long-random
ADMIN_JWT_SECRET=change-me-long-random

# --- Root admin bootstrap (seeded on first boot if missing) ---
ADMIN_ROOT_EMAIL=admin@zbarber.net
ADMIN_ROOT_PASSWORD=change-me-strong
# URL shown in admin invite emails (this env's admin domain)
ADMIN_LOGIN_URL=https://admin.zbarber.net
# Address that receives admin notifications (e.g. new barber requests)
ADMIN_NOTIFICATION_EMAIL=admin@zbarber.net

# --- Clerk (mobile auth via API proxy) ---
CLERK_SECRET_KEY=sk_live_xxx
CLERK_PUBLISHABLE_KEY=pk_live_xxx

# --- SMTP (optional — admin invites & 24h reminder emails) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Zbarber <no-reply@zbarber.net>"

# --- Object storage ---
# Images (avatars, salon logos, gallery photos, before/after realisations, panoramas,
# article covers, financing docs) are stored by one of three backends, chosen by
# OBJECT_STORAGE_PROVIDER: "local" (VPS disk — recommended here), "gcs", or "replit".
#
# ===========================================================================
# Option A (RECOMMENDED on this VPS): local disk — no per-GB / egress cost.
# ===========================================================================
OBJECT_STORAGE_PROVIDER=local
#
# Directory where uploaded files are written (use a SEPARATE dir per environment).
#   prod: /srv/zbarber/storage/prod
#   test: /srv/zbarber/storage/test
# Create it once and give it to the service user:
#   sudo mkdir -p /srv/zbarber/storage/prod /srv/zbarber/storage/test
#   sudo chown -R zbarber:zbarber /srv/zbarber/storage
LOCAL_STORAGE_DIR=/srv/zbarber/storage/prod
#
# Notes:
#  - Uploads now flow through nginx → the API (PUT /api/storage/local-upload/...),
#    so nginx `client_max_body_size` must be >= the max image size (already 25m
#    in deploy/nginx/api*.conf). The API enforces the same 25 MiB cap.
#  - Upload URLs are HMAC-signed with SESSION_SECRET — keep it set and secret.
#  - ⚠️ Local disk has NO redundancy/backup. Back up LOCAL_STORAGE_DIR yourself
#    (e.g. a nightly rsync/cron of /srv/zbarber/storage to another disk/host).
#  - PRIVATE_OBJECT_DIR / PUBLIC_OBJECT_SEARCH_PATHS / GCS_* below are IGNORED
#    when the provider is "local".
#
# ===========================================================================
# Option B: real Google Cloud Storage bucket (paid; per-GB + egress).
# ===========================================================================
# Set OBJECT_STORAGE_PROVIDER=gcs instead, then:
#   1. Create a GCS bucket (one for prod, one for test).
#   2. Create a service account with the "Storage Object Admin" role on that bucket
#      (read, write, set metadata, AND sign URLs — the latter needs the
#      "Service Account Token Creator" role or a key with a private key).
#   3. Download its JSON key to the VPS, e.g. /etc/zbarber/gcs-prod-sa.json
#      (chmod 600, owned by the zbarber user).
# GOOGLE_APPLICATION_CREDENTIALS=/etc/zbarber/gcs-prod-sa.json
# ...OR inline (single line, escaped JSON). Use ONE of the two, not both:
# GCS_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"..."}
# Optional: explicit GCP project id (otherwise inferred from the key).
# GCS_PROJECT_ID=
# Bucket layout. First path segment = bucket name; the rest is a prefix.
# PRIVATE_OBJECT_DIR=/zbarber-prod/.private
# PUBLIC_OBJECT_SEARCH_PATHS=/zbarber-prod/public
